**/node_modules/
build/
dist/
!server/dist/
coverage/
.DS_Store
._*
*.log

# Ambientes e segredos (Admin, APIs, Supabase service role, senhas locais)
.env
.env.*
!.env.example
!server/.env.example
!mobile/.env.example
.env.local
.env.*.local
*.pem
secrets/

# NPM — ficheiros .npmrc podem conter token de registry
.npmrc

# Arquivo consolidado temporário de bootstrap Supabase — gerado por cat migrations/
supabase/CONSOLIDATED_BOOTSTRAP.sql
supabase/SEED_GENESIS_WITH_PORTRAITS.sql

# Mobile / Expo
mobile/.env
mobile/.env.*
!mobile/.env.example

# Sub-Apps Vite
web/match-pitch/.env
web/match-pitch/.env.*
!web/match-pitch/.env.example

# Espelho opcional / checkout local de outro repo — não versionar (evita gitlink quebrado)
/legacy/

# Supabase CLI (estado local / branches)
supabase/.temp
supabase/.branches

# Android / Firebase (credenciais de projeto)
google-services.json
GoogleService-Info.plist
*.jks
*.keystore

# Cursor — config local (MCP, etc.); não versionar para não expor tokens/refs
.cursor/

# Claude Code — symlinks/cópia local das skills (fonte versionada em .agents/skills)
.claude/

# Ferramentas / caches
.turbo
.vercel
*.tsbuildinfo

# Python cache
**/__pycache__/
*.pyc

# MCP per-user config
.mcp.json
scripts/calibration/raw/

# Documentos estratégicos / IP confidencial — não versionar
.docs/IP_Inventory_*.md
.docs/NDA_*.md
.docs/olefoot-system-map.md
# Dumps de banco — podem conter dados pessoais (emails, hashes)
*.sql
!supabase/migrations/*.sql
!supabase/seed*.sql
!server/migrations/*.sql

# Migration v1 → v11: snapshots locais com bcrypt hashes, emails, wallets, balances
scripts/migrate-legacy-v1/data/

# Banco do sistema antigo (dumps, tar.gz, jsons com bcrypt/mnemonicos/chaves) — NUNCA versionar
olefoot-db/

# Cloudflare Wrangler — cache local (contém id de conta, não versionar)
.wrangler/
