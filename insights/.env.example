# OLEFOOT PYTHON MODE — insights service env vars
# Copy to .env and fill values from Supabase project settings.

# Supabase project URL (https://xxxxx.supabase.co)
SUPABASE_URL=

# Service role key — bypasses RLS, NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — used to verify tokens from Hono proxy.
# Get from Supabase: Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# Optional: comma-separated origins allowed via CORS.
# Default: http://localhost:5173 (Vite dev) + https://*.olefoot.com
CORS_ORIGINS=http://localhost:5173

# Optional: log level (DEBUG, INFO, WARNING)
LOG_LEVEL=INFO
