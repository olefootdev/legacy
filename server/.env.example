# Copia para `server/.env`. Nunca commits ficheiros `.env` com valores reais.
# ─── Supabase (obrigatório para o servidor) ──────────────────────────
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"
# Service role: só no servidor — NUNCA no frontend ou repositório público.
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Opcional ────────────────────────────────────────────────────────
# DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# ─── OpenAI — Admin Game Spirit (ensino estruturado) ─────────────────
# POST /api/game-spirit/teach — nunca expor esta chave no bundle Vite.
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
