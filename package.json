{
  "name": "olefoot-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pitch": "npm run dev --prefix web/match-pitch",
    "build": "vite build",
    "builder": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && tsc --noEmit -p web/match-pitch/tsconfig.json && tsc --noEmit -p web/match-pitch/tsconfig.node.json",
    "test:field-smoke": "tsx src/field-schema/runSmoke.ts",
    "demo:sim-pipeline": "tsx src/match/events/runScenarioDemo.ts",
    "test:causal": "tsx src/match/causal/runCausalSelfTest.ts",
    "test:impact-ledger": "tsx src/match/runImpactLedgerSelfTest.ts",
    "test:spirit-machine": "tsx src/gamespirit/runSpiritStateMachineSelfTest.ts",
    "test:structural": "tsx src/simulation/runStructuralSelfTest.ts",
    "test:turnover": "tsx src/simulation/runPickPlayAfterTurnoverTest.ts",
    "test:collective-individual": "tsx src/playerDecision/runCollectiveIndividualSelfTest.ts",
    "test:attribute-impact": "tsx src/simulation/runAttributeImpactSelfTest.ts",
    "test:field-zones": "tsx src/match/runFieldZonesSelfTest.ts",
    "test:shot-resolve": "tsx src/simulation/runShotResolveSelfTest.ts",
    "test:shoot-pipeline": "tsx src/simulation/runShootPipelineSelfTest.ts && tsx src/simulation/runShootSimIntegrationSelfTest.ts",
    "test:possession-invariant": "tsx src/match/runPossessionInvariantSelfTest.ts",
    "test:deliberation": "tsx src/playerDecision/runDeliberationSelfTest.ts",
    "test:spatial-goals": "tsx src/match/runSpatialGoalsSelfTest.ts",
    "test:player-speed": "tsx src/match/runPlayerSpeedSelfTest.ts",
    "test:live-story": "tsx src/gamespirit/runLiveStorySelfTest.ts",
    "test:playing-style": "tsx src/playerDecision/runPlayingStyleSelfTest.ts",
    "dev:server": "npm run dev --prefix server"
  },
  "dependencies": {
    "@babylonjs/core": "^7.54.3",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.3",
    "yuka": "^0.7.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
