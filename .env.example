# Copia para `.env` na raiz e preenche com os teus valores. Nunca commits `.env`.
# ─── API-Football (api-sports.io) — cadastro “time do coração”, escudos ──
# Chave no dashboard: https://dashboard.api-football.com
# Em `npm run dev` o Vite faz proxy de `/api-football` e injeta este header (não expõe no bundle).
API_FOOTBALL_KEY=""
# Produção (SPA estática): só se fizeres fetch directo no browser — expõe a chave; preferir proxy no teu servidor.
# VITE_API_FOOTBALL_KEY=""

# ─── Gemini AI ───────────────────────────────────────────────────────
# Usado pelo Admin → Create player (GameSpirit interpreta prompt → JSON jogador).
# Injeta no bundle via vite.config `define`; em produção preferir proxy no servidor.
GEMINI_API_KEY=""

# URL do olefoot-server (Admin → Game Spirit → OpenAI / status). Por omissão http://localhost:4000
VITE_OLEFOOT_API_URL="http://localhost:4000"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:5173"

# ─── Supabase (cliente — anon key é pública no browser; RLS protege dados) ──
# Cria o projeto em https://supabase.com e cola URL + anon key (Settings → API).
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# ─── Server only — NUNCA no bundle do browser/mobile ────────────────
# Ver server/.env.example para variáveis exclusivas da API.
# SUPABASE_SERVICE_ROLE_KEY=""
# DATABASE_URL=""
