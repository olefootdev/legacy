# Copiar para `.env` na raiz e preencher localmente. Nunca commitar `.env`.
#
# ─── API-Football (proxy Vite em dev) ─────────────────────────────────
# Dashboard: https://dashboard.api-football.com
API_FOOTBALL_KEY=
# Opcional: VITE_API_FOOTBALL_PROXY=  (true em preview se usares proxy)
# Opcional: VITE_API_FOOTBALL_KEY=     (só se fetch direto no browser — expõe chave)

# ─── Gemini (Admin → Create player) ───────────────────────────────────
# Injeta em build via Vite; em produção preferir proxy no servidor.
GEMINI_API_KEY=

# ─── olefoot-server (Game Spirit / API local) ─────────────────────────
VITE_OLEFOOT_API_URL=
APP_URL=

# ─── Supabase (cliente Vite — anon key é pública no bundle; RLS no servidor)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Opcional / dev ───────────────────────────────────────────────────
# DISABLE_HMR=true

# Servidor Node: ver `server/.env.example` (service role, OpenAI, etc.)
